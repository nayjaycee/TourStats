    "def line_chart(ycol: str, ylabel: str, title: str):\n",
    "    if ycol not in dfp.columns:\n",
    "        raise KeyError(f\"Column '{ycol}' not found. Available: {list(dfp.columns)}\")\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(14, 3.2))\n",
