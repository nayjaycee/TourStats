    "def plot_day_two_panel_with_rug(dfp, day, tee_times=None, tee_labels=None):\n",
    "    d = dfp.copy()\n",
    "    d[\"dt_local\"] = pd.to_datetime(d[\"dt_local\"], errors=\"coerce\")\n",
