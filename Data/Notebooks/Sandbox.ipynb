    "    gust = d[\"gust_mph\"]\n",
    "    rain = d[\"chance_of_rain\"].clip(0, 100)\n",
    "    precip = d[\"precip_in\"].clip(lower=0)\n",
    "\n",
    "    tees = None\n",
    "    if tee_times is not None:\n",
    "        tees = [pd.to_datetime(t) for t in tee_times]\n",
    "\n",
    "    c_wind = \"#4C78A8\"\n",
    "    c_gust = \"#F58518\"\n",
    "    c_rain = \"#54A24B\"\n",
    "    c_prec = \"#72B7B2\"\n",
