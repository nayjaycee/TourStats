    "waves = [\n",
    "    (\"2026-02-19 07:00\", \"2026-02-19 08:15\", \"AM wave\"),\n",
    "    (\"2026-02-19 11:00\", \"2026-02-19 12:15\", \"Late AM / Midday\"),\n",
    "]\n",
    "\n",
    "plot_day_two_panel(\n",
